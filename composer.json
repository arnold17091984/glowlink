{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3 || ^8.2.20",
        "bezhansalleh/filament-language-switch": "*",
        "filament/filament": "^3.2",
        "filament/notifications": "^3.2",
        "filament/spatie-laravel-media-library-plugin": "^3.2",
        "guzzlehttp/guzzle": "^7.2",
        "laravel/framework": "^11.19",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.8",
        "league/flysystem-aws-s3-v3": "3.0",
        "linecorp/line-bot-sdk": "^9.7",
        "pxlrbt/filament-activity-log": "^1.0",
        "sentry/sentry-laravel": "^4.7",
        "spatie/laravel-activitylog": "^4.7",
        "spatie/laravel-medialibrary": "*",
        "spatie/laravel-query-builder": "^6.0",
        "spatie/laravel-route-attributes": "^1.20"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.10",
        "barryvdh/laravel-ide-helper": "*",
        "fakerphp/faker": "^1.9.1",
        "laravel/homestead": "^15.0",
        "laravel/pint": "*",
        "laravel/sail": "^1.31",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/larastan": "^2.9",
        "phpunit/phpunit": "^10.1",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "analyse-no-memory-limit": "vendor/bin/phpstan analyse --memory-limit=-1",
        "analyse-generate-baseline": "vendor/bin/phpstan analyse --generate-baseline",
        "format": "./vendor/bin/pint",
        "format-dirty": "./vendor/bin/pint --dirty",
        "format-dry-run": "./vendor/bin/pint --test",
        "test": "vendor/bin/pest --parallel",
        "test-no-timeout": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/pest --parallel"
        ],
        "test-coverage": "vendor/bin/pest --parallel --coverage-html build/coverage",
        "refactor": "vendor/bin/rector process",
        "refactor-dry-run": "vendor/bin/rector process --dry-run",
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan vendor:publish --provider=\"romanzipp\\QueueMonitor\\Providers\\QueueMonitorProvider\" --tag=assets --ansi --force",
            "@php artisan vendor:publish --tag=horizon-assets --ansi --force",
            "@php artisan filament:upgrade",
            "@php artisan ide-helper:generate --ansi",
            "@php artisan ide-helper:meta --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "ide-helper": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "@php artisan ide-helper:generate --ansi",
            "@php artisan ide-helper:meta --ansi"
        ],
        "ide-helper-model": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "@php artisan ide-helper:generate --ansi",
            "@php artisan ide-helper:meta --ansi",
            "@php artisan ide-helper:models -r -W --ansi",
            "@php artisan tenants:run ide-helper:models --option=\"smart-reset=1\" --option=\"write=1\" --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "barryvdh/laravel-ide-helper"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
